@page
@model myapp.Pages.IndexModel
@{
    ViewData["Title"] = "IPL Report";
}

<div class="ant-row" style="margin-bottom: 24px;">
    <div class="ant-col ant-col-24">
        <div class="ant-card">
            <div class="ant-card-body">
                <h1 class="display-4">Welcome to the IPL Report</h1>
                <p>Select a category to view the information.</p>
            </div>
        </div>
    </div>
</div>

<div class="ant-row" style="margin: -12px;">
    <div class="ant-col ant-col-xs-24 ant-col-sm-12 ant-col-md-8" style="padding: 12px;">
        <div class="ant-card">
            <div class="ant-card-body">
                <div class="ant-card-meta">
                    <div class="ant-card-meta-avatar">
                        <span class="anticon anticon-user"></span>
                    </div>
                    <div class="ant-card-meta-detail">
                        <div class="ant-card-meta-title">Players</div>
                        <div class="ant-card-meta-description">@Model.PlayerCount</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="ant-col ant-col-xs-24 ant-col-sm-12 ant-col-md-8" style="padding: 12px;">
        <div class="ant-card">
            <div class="ant-card-body">
                <div class="ant-card-meta">
                    <div class="ant-card-meta-avatar">
                        <span class="anticon anticon-team"></span>
                    </div>
                    <div class="ant-card-meta-detail">
                        <div class="ant-card-meta-title">Teams</div>
                        <div class="ant-card-meta-description">@Model.TeamCount</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="ant-col ant-col-xs-24 ant-col-sm-12 ant-col-md-8" style="padding: 12px;">
        <div class="ant-card">
            <div class="ant-card-body">
                <div class="ant-card-meta">
                    <div class="ant-card-meta-avatar">
                        <span class="anticon anticon-crown"></span>
                    </div>
                    <div class="ant-card-meta-detail">
                        <div class="ant-card-meta-title">Coaches</div>
                        <div class="ant-card-meta-description">@Model.CoachCount</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

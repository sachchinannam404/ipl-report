<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IPL Report</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/antd/4.17.2/antd.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/ant-design-icons/4.7.0/antd-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="ant-layout-has-sider">
    <div class="ant-layout">
        <div class="ant-layout-sider" style="background: #001529;">
            <div class="logo" style="padding: 10px; text-align: center;">
                <a asp-page="/Index">
                    <img src="/images/logo.png" alt="IPL Report" style="height: 40px;" />
                </a>
            </div>
            <ul class="ant-menu ant-menu-dark ant-menu-root ant-menu-inline" style="background: #001529;">
                <li class="ant-menu-item">
                    <a class="nav-link" asp-area="" asp-page="/Players"><span class="anticon anticon-user"></span><span class="nav-text">Players</span></a>
                </li>
                <li class="ant-menu-item">
                    <a class="nav-link" asp-area="" asp-page="/Teams"><span class="anticon anticon-team"></span><span class="nav-text">Teams</span></a>
                </li>
                <li class="ant-menu-item">
                    <a class="nav-link" asp-area="" asp-page="/Coaches"><span class="anticon anticon-crown"></span><span class="nav-text">Coaches</span></a>
                </li>
                <li class="ant-menu-item">
                    <a class="nav-link" asp-area="" asp-page="/Winners"><span class="anticon anticon-trophy"></span><span class="nav-text">Winners</span></a>
                </li>
            </ul>
        </div>
        <div class="ant-layout" style="background: #f0f2f5;">
            <div class="ant-layout-header" style="background: #fff; padding: 0 24px;">
                <h1 style="font-size: 24px; color: #001529;">@ViewData["Title"]</h1>
            </div>
            <div class="ant-layout-content" style="padding: 24px;">
                @RenderBody()
            </div>
            <div class="ant-layout-footer" style="text-align: center; background: #f0f2f5;">
                &copy; 2024 - IPL Report
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/antd/4.17.2/antd.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@page
@model myapp.Pages.PlayersModel

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Team</th>
            <th>Position</th>
            <th>Batting</th>
            <th>Throwing</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var player in Model.Players)
        {
            <tr>
                <td>@player.Name</td>
                <td>@player.Team</td>
                <td>@player.Position</td>
                <td>@player.Batting</td>
                <td>@player.Throwing</td>
            </tr>
        }
    </tbody>
</table>

@page
@model myapp.Pages.PlayersModel

@{ ViewData["Title"] = "Players";
}

<div class="container">
    <h1>Players</h1>
    <p>This is the page for Players.</p>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>Name</th>
                    <th>Team</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var player in Model.Players)
                {
                    <tr>
                        <td>@player.Name</td>
                        <td>@player.Team</td>
                        <td>@player.Role</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

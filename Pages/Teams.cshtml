@page
@model myapp.Pages.TeamsModel
@{
    ViewData["Title"] = "Teams";
}

<div class="ant-row" style="margin: -12px;">
    @foreach (var team in Model.Teams)
    {
        <div class="ant-col ant-col-xs-24 ant-col-sm-12 ant-col-md-8" style="padding: 12px;">
            <div class="ant-card">
                <div class="ant-card-head">
                    <div class="ant-card-head-wrapper">
                        <div class="ant-card-head-title">@team.Name</div>
                    </div>
                </div>
                <div class="ant-card-body">
                    <p><strong>Coach:</strong> @team.Coach</p>
                    <p><strong>City:</strong> @team.City</p>
                    <p><strong>Home Ground:</strong> @team.HomeGround</p>
                </div>
            </div>
        </div>
    }
</div>

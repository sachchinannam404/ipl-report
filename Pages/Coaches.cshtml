@page
@model myapp.Pages.CoachesModel

@{ ViewData["Title"] = "Coaches";
}

<div class="container">
    <h1>Coaches</h1>
    <p>This is the page for Coaches.</p>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>Name</th>
                    <th>Team</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coach in Model.Coaches)
                {
                    <tr>
                        <td>@coach.Name</td>
                        <td>@coach.Team</td>
                        <td>@coach.Role</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
